# =============================================================================
# Jiwan Pathshala / Life Trends — environment variable template
# =============================================================================
# Copy this file to `.env` for local use and fill in real values.
# DO NOT commit `.env` to git (it is in .gitignore).
# In production, set these in your provider's dashboard:
#   - Vercel:  Project → Settings → Environment Variables
#   - Render:  Service → Environment
#   - Railway: Project → Variables
# -----------------------------------------------------------------------------

# ---- Runtime (server) ------------------------------------------------------
# Port the static server binds to. Render sets this automatically (10000).
# Railway/Vercel inject their own PORT. Override only for local dev.
PORT=3000

# Node environment. Most hosts set this for you.
NODE_ENV=production

# ---- Public (frontend-safe) variables --------------------------------------
# These are exposed to the browser. NEVER put secrets here.

# Optional: default Google Sheet CSV URL the app pre-loads at boot.
# Leave blank to keep the in-page input field as the only data source.
PUBLIC_SHEET_CSV_URL=

# Optional: override the app title shown in the nav bar.
PUBLIC_APP_TITLE=Jiwan Pathshala Generational Mapping

# ---- Server-only secrets (DO NOT prefix with PUBLIC_) ----------------------
# These are placeholders for future server-side integrations. The current
# static app does NOT read any of them, but the preflight script will warn
# if they are required by a feature flag you add later.

# Example: Sentry error reporting DSN (server side).
# SENTRY_DSN=

# Example: API key for a future analytics backend.
# ANALYTICS_API_KEY=

# Example: token for fetching private Google Sheets via a server proxy.
# GOOGLE_SHEETS_API_KEY=
